{
  "name": "@lass-lang/cli",
  "version": "0.0.1",
  "description": "Lass CLI - compile .lass files to CSS",
  "author": "Long-lazuli",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "lass": "./dist/bin/lass.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "dependencies": {
    "@lass-lang/core": "^0.0.1",
    "@lass-lang/plugin-utils": "^0.0.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "husky": "^9.1.7",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "lass",
    "css",
    "cli",
    "compiler",
    "preprocessor",
    "transpiler"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lass-lang/cli.git"
  },
  "bugs": {
    "url": "https://github.com/lass-lang/cli/issues"
  },
  "homepage": "https://github.com/lass-lang/cli#readme"
}
